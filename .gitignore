# ---------------------------------------------------------------------------
# Clarity project — .gitignore
# ---------------------------------------------------------------------------

# ECC plugin (not part of the project)
everything-claude-code/

# Environment variables
.env
*.env
.env.local

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Virtual environments
.venv/
venv/

# ML model artifacts (large binary files)
ml/clearconsent-distilbert/
ml/clearconsent-distilbert-v2/
ml/**/checkpoint-*/
ml/**/*.safetensors
ml/**/*.pt
ml/**/*.bin

# SQLite database
*.db

# Frontend
node_modules/
dist/

# Logs
*.log

# OS / editor
.DS_Store
.idea/
.vscode/
.gemini/
